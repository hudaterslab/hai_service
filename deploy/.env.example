# Copy this file to deploy/.env on the target host and adjust paths as needed.
# Or run:
#   ./scripts/linux/deploy-stack.sh init
#
# If the project lives at:
#   /media/fishduke/06800C3B800C3429/WorkWithCodex/vms-8ch-webrtc
# then keep VMS_DATA_ROOT under the same disk so container data also stays there.

VMS_DATA_ROOT=/media/fishduke/06800C3B800C3429/WorkWithCodex/vms-8ch-webrtc/runtime
DXRT_HOST_DIR=/opt/deepx/dx_rt
DXRT_HOST_LIB_DIR=/usr/local/lib
DELIVERY_DEDUP_WINDOW_SEC=10
# Optional: set to a different published port if 18081 is occupied on the host.
# DXNN_HOST_PORT=18081
#
# If you do not use DXRT / DeepX runtime yet, keep the variables above but make sure
# the referenced host directories exist before bringing the stack up.
